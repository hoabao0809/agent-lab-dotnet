@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-1 right-1 text-success-light text-lg font-bold animate-slideup">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-2 text-center rounded-xl transition-all duration-200 select-none min-h-[70px] text-xs leading-tight font-semibold hover:scale-105 active:scale-95 cursor-pointer";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-warm-gradient text-white shadow-lg border-2 border-warm animate-pulse"
                : "bg-gradient-to-br from-success to-accent text-white shadow-lg border-2 border-success-light"
            : "bg-gradient-to-br from-purple-800 to-indigo-900 text-light border-2 border-purple-600 hover:border-accent hover:shadow-lg hover:shadow-accent/30";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-black text-sm text-accent cursor-default opacity-60 bg-dark-card border-dashed" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
