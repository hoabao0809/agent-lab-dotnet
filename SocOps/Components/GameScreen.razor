@using SocOps.Models

<div class="flex flex-col min-h-full bg-gradient-to-b from-slate-900 via-purple-900 to-slate-900">
    <!-- Header -->
    <header class="flex items-center justify-between p-4 bg-dark-card">
        <button
            @onclick="OnReset"
            class="text-accent hover:text-accent-light font-semibold px-4 py-2 rounded-lg transition-colors duration-200 flex items-center gap-2">
            ← Back
        </button>
        <h1 class="font-black text-xl text-light">Soc<span class="text-accent">Ops</span></h1>
        <div class="w-16"></div>
    </header>

    <!-- Progress Indicator -->
    <div class="px-6 py-4">
        <p class="text-center text-text-secondary text-sm font-medium">
            ✨ Tap squares to find your match! ✨
        </p>
    </div>

    <!-- Bingo Alert -->
    @if (HasBingo)
    {
        <div class="mx-4 mb-4 bg-warm-gradient text-white text-center py-3 font-bold text-sm rounded-xl shadow-lg animate-pulse">
            🎉 BINGO! You got a line! 🎉
        </div>
    }

    <!-- Board Container -->
    <div class="flex-1 flex items-center justify-center px-4 pb-6">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
